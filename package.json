{
  "name": "fitbit-private-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Private Fitbit health dashboard and MCP server on Cloudflare Workers",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "protobufjs", "sharp", "workerd"]
  },
  "scripts": {
    "clean": "rm -rf dist && sol clean --all",
    "generate": "sol generate && node scripts/patch-types.js",
    "build:moon": "moon build --target js --release",
    "build:patch": "node scripts/patch-for-cloudflare.js _build/js/release/build/__gen__/server/server.js && node scripts/patch-for-cloudflare.js _build/js/release/build/server/server.js",
    "build:client": "node scripts/bundle-client.js",
    "build:bundle": "wrangler deploy --dry-run --outdir=dist",
    "build:verify": "node scripts/check-worker-bundle.ts dist/worker.js",
    "build": "pnpm run clean && pnpm run generate && pnpm run build:moon && pnpm run build:patch && pnpm run build:client && pnpm run build:bundle && pnpm run build:verify",
    "check": "moon check --target js && tsc --noEmit",
    "types": "wrangler types",
    "dev": "pnpm run build && wrangler dev --port 18787",
    "deploy": "pnpm run build && wrangler deploy",
    "db:create": "wrangler d1 create fitbit-health-db",
    "db:init": "wrangler d1 execute fitbit-health-db --local --file=migrations/0001_create_tables.sql",
    "db:migrate": "wrangler d1 migrations apply fitbit-health-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply fitbit-health-db",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:mcp": "playwright test mcp.spec.ts",
    "test:dashboard": "playwright test dashboard.spec.ts",
    "test:oauth": "playwright test oauth.spec.ts --headed",
    "lint:secretlint": "git ls-files -co --exclude-standard -z | xargs -0 secretlint"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "hono": "^4.11.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@luna_ui/sol": "0.22.1",
    "@playwright/test": "^1.57.0",
    "@secretlint/secretlint-rule-preset-recommend": "9.0.0",
    "@types/node": "24.0.0",
    "axe-core": "^4.11.0",
    "dotenv": "^17.2.3",
    "esbuild": "^0.27.2",
    "secretlint": "9.0.0",
    "typescript": "5.9.3",
    "wrangler": "4.107.1"
  }
}
